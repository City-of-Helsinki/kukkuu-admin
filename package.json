{
  "name": "kukkuu-admin",
  "version": "4.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "app:version": "echo \"$npm_package_version\"",
    "start": "vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsc && vite build",
    "serve": "vite preview",
    "typecheck": "tsc",
    "typecheck:e2e": "tsc --project tsconfig.e2e.json",
    "test": "cross-env TZ=Europe/Helsinki vitest run",
    "test:coverage": "cross-env TZ=Europe/Helsinki NODE_OPTIONS=--max-old-space-size=8192 vitest run --coverage",
    "test:staged": "cross-env TZ=Europe/Helsinki vitest related --run",
    "test:watch": "cross-env TZ=Europe/Helsinki vitest",
    "lint": "eslint --ext js,jsx,ts,tsx,cjs,mjs src e2e",
    "format:code": "yarn lint --fix",
    "format:markup": "prettier --config .prettierrc.json --write \"./**/*.{html,json,css,scss,md,mdx}\"",
    "generate:graphql": "cross-env DOTENV_CONFIG_PATH=./.env graphql-codegen -r dotenv/config --config ./codegen.ts",
    "test:e2e:install": "playwright install",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@apollo/client": "^3.8.4",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@hookform/resolvers": "^3.3.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@nabla/vite-plugin-eslint": "^3.0.1",
    "@sentry/browser": "^10.58.0",
    "@tanstack/react-query": "^5.101.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/apollo-upload-client": "^17.0.3",
    "@types/classnames": "^2.3.4",
    "@types/dotenv": "^8.2.3",
    "@types/history": "^5.0.0",
    "@types/lodash": "^4.14.199",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.13",
    "apollo-upload-client": "^17.0.0",
    "axios": "^1.16.0",
    "classnames": "^2.5.1",
    "codecov": "^3.8.3",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vitest-globals": "^1.6.1",
    "graphql": "^16.8.1",
    "history": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "oidc-client-ts": "^3.0.1",
    "prettier": "^3.4.2",
    "query-string": "^8.1.0",
    "ra-language-english": "^5.14.7",
    "ra-language-finnish": "^5.7.0",
    "ra-language-swedish": "^1.0.0",
    "react": "^19.2.7",
    "react-admin": "^5.14.7",
    "react-dom": "^19.2.7",
    "react-idle-timer": "^5.7.2",
    "react-router-dom": "^7.18.0",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "^4.1.0",
    "vitest-localstorage-mock": "^0.1.2",
    "vitest-sonar-reporter": "^2.0.0",
    "yup": "^1.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typescript-react-apollo": "^4.1.0",
    "@playwright/test": "^1.61.1",
    "@types/jsonwebtoken": "^9.0.10",
    "doctoc": "^2.2.1",
    "full-icu": "^1.5.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.4.3"
  },
  "resolutions": {
    "@types/minimatch": "^5.1.2",
    "lodash": "^4.18.1",
    "underscore": "^1.13.8",
    "shell-quote": ">=1.8.4",
    "form-data": ">=4.0.6",
    "qs": ">=6.2.4",
    "ws": ">=8.21.0",
    "dompurify": ">=3.4.11"
  }
}
